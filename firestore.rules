rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'displayName', 'avatarUrl', 'jobTitle', 'skills', 'tools', 'bio', 'howToReachMe', 'openToWork', 'createdAt'])
        && data.id is string
        && data.displayName is string && data.displayName.size() >= 2 && data.displayName.size() <= 100
        && data.avatarUrl is string && data.avatarUrl.size() <= 20000000
        && data.jobTitle is string
        && data.skills is list
        && data.tools is list
        && data.bio is string
        && data.howToReachMe is string
        && data.openToWork is bool;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'ownerId', 'ownerName', 'ownerAvatar', 'title', 'pitch', 'description', 'collabType', 'engine', 'teamNeeds', 'recruitments', 'status', 'createdAt'])
        && data.id is string
        && data.ownerId is string
        && data.title is string && data.title.size() >= 3 && data.title.size() <= 200
        && data.pitch is string && data.pitch.size() <= 500
        && data.description is string && data.description.size() <= 5000
        && data.collabType is string
        && data.engine is string
        && data.teamNeeds is list
        && data.recruitments is list
        && data.status is string
        && (!data.keys().hasAny(['videoDemoUrl']) || data.videoDemoUrl is string)
        && (!data.keys().hasAny(['showcaseImages']) || data.showcaseImages is list)
        && (!data.keys().hasAny(['hiringType']) || data.hiringType is string)
        && (!data.keys().hasAny(['budgetDescription']) || data.budgetDescription is string)
        && (!data.keys().hasAny(['inspiration']) || data.inspiration is string)
        && (!data.keys().hasAny(['tasks']) || data.tasks is list)
        && (!data.keys().hasAny(['meetLink']) || data.meetLink is string);
    }

    function isValidPortfolio(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'mediaUrl', 'mediaType', 'description'])
        && data.id is string
        && data.userId is string
        && data.title is string && data.title.size() >= 2 && data.title.size() <= 200
        && data.mediaUrl is string && data.mediaUrl.size() <= 20000000
        && data.mediaType is string
        && data.description is string;
    }

    function isValidConnection(data) {
      return data.keys().hasAll(['id', 'fromUserId', 'toUserId', 'fromUserName', 'toUserName', 'fromUserAvatar', 'toUserAvatar', 'status', 'createdAt'])
        && data.keys().hasOnly(['id', 'fromUserId', 'toUserId', 'fromUserName', 'toUserName', 'fromUserAvatar', 'toUserAvatar', 'status', 'createdAt', 'message', 'acceptedAt'])
        && data.id is string
        && data.fromUserId is string
        && data.toUserId is string
        && data.fromUserId != data.toUserId
        && data.fromUserName is string
        && data.toUserName is string
        && data.fromUserAvatar is string
        && data.toUserAvatar is string
        && data.status in ['pending', 'accepted', 'declined']
        && data.createdAt is string
        && (!data.keys().hasAny(['message']) || data.message is string)
        && (!data.keys().hasAny(['acceptedAt']) || data.acceptedAt is string || data.acceptedAt == null);
    }

    function isConnectionMember(data) {
      return signedIn() && (data.fromUserId == uid() || data.toUserId == uid());
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['conversationId', 'senderId', 'senderName', 'senderAvatar', 'content', 'createdAt', 'readBy', 'participantIds'])
        && data.senderId == uid()
        && data.participantIds is list
        && uid() in data.participantIds
        && data.content is string
        && data.content.size() >= 1
        && data.content.size() <= 2000;
    }

    function isWorkspaceMember(workspaceId) {
      let ws = get(/databases/$(database)/documents/project_workspaces/$(workspaceId)).data;
      return signedIn() && (ws.ownerId == uid() || uid() in ws.memberIds);
    }

    function canCreateStudio() {
      let user = get(/databases/$(database)/documents/users/$(uid())).data;
      return signedIn()
        && user.profileComplete == true
        && user.isGuest != true
        && user.skills is list
        && user.skills.size() > 0
        && user.tools is list
        && user.tools.size() > 0
        && user.bio is string
        && user.bio.size() > 0
        && user.howToReachMe is string
        && user.howToReachMe.size() > 0;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSelf(userId)
        && request.resource.data.id == userId
        && isValidUser(request.resource.data);
      allow delete: if isSelf(userId);
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.ownerId == uid()
        && request.resource.data.id == projectId
        && isValidProject(request.resource.data);
      allow update: if signedIn()
        && resource.data.ownerId == uid()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.id == resource.data.id
        && isValidProject(request.resource.data);
      allow delete: if signedIn() && resource.data.ownerId == uid();
    }

    match /portfolios/{portfolioId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.userId == uid()
        && request.resource.data.id == portfolioId
        && isValidPortfolio(request.resource.data);
      allow delete: if signedIn() && resource.data.userId == uid();
    }

    match /studios/{studioId} {
      allow read: if true;
      allow create: if signedIn()
        && canCreateStudio()
        && request.resource.data.ownerId == uid()
        && request.resource.data.id == studioId
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 100
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 10
        && request.resource.data.description.size() <= 5000
        && request.resource.data.avatarUrl is string
        && request.resource.data.members is list
        && request.resource.data.memberIds is list
        && uid() in request.resource.data.memberIds;
      allow update: if signedIn()
        && (
          (
            resource.data.ownerId == uid()
            && request.resource.data.ownerId == resource.data.ownerId
          )
          ||
          (
            resource.data.memberIds is list
            && resource.data.members is list
            && uid() in resource.data.memberIds
            && request.resource.data.memberIds is list
            && request.resource.data.members is list
            && !(uid() in request.resource.data.memberIds)
            && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1
            && request.resource.data.members.size() == resource.data.members.size() - 1
            && request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.id == resource.data.id
            && request.resource.data.name == resource.data.name
            && request.resource.data.description == resource.data.description
            && request.resource.data.avatarUrl == resource.data.avatarUrl
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberIds'])
          )
        );
      allow delete: if signedIn() && resource.data.ownerId == uid();
    }

    match /project_applications/{applicationId} {
      allow read: if signedIn() && (resource.data.userId == uid() || resource.data.ownerId == uid());
      allow create: if signedIn()
        && request.resource.data.id == applicationId
        && request.resource.data.userId == uid()
        && request.resource.data.ownerId is string
        && request.resource.data.projectId is string
        && get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.ownerId == request.resource.data.ownerId
        && request.resource.data.ownerId != uid()
        && request.resource.data.status == 'pending'
        && request.resource.data.roleApplied is string
        && request.resource.data.message is string;
      allow update: if signedIn()
        && resource.data.ownerId == uid()
        && request.resource.data.id == resource.data.id
        && request.resource.data.projectId == resource.data.projectId
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.status in ['approved', 'rejected']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']);
      allow delete: if signedIn() && (resource.data.userId == uid() || resource.data.ownerId == uid());
    }

    match /project_workspaces/{projectId} {
      allow read: if signedIn() && (resource.data.ownerId == uid() || uid() in resource.data.memberIds);
      allow create: if signedIn()
        && request.resource.data.id == projectId
        && request.resource.data.ownerId == uid()
        && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == uid()
        && request.resource.data.memberIds is list
        && uid() in request.resource.data.memberIds;
      allow update: if signedIn()
        && (
          (
            resource.data.ownerId == uid()
            && request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.id == resource.data.id
          )
          ||
          (
            uid() in resource.data.memberIds
            && request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.id == resource.data.id
            && request.resource.data.memberIds == resource.data.memberIds
            && request.resource.data.memberProfiles == resource.data.memberProfiles
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['goals', 'tasks', 'files'])
          )
          ||
          (
            uid() in resource.data.memberIds
            && resource.data.ownerId != uid()
            && !(uid() in request.resource.data.memberIds)
            && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1
            && request.resource.data.memberProfiles.size() == resource.data.memberProfiles.size() - 1
            && request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.id == resource.data.id
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberProfiles'])
          )
        );
      allow delete: if signedIn() && resource.data.ownerId == uid();

      match /messages/{messageId} {
        allow read: if isWorkspaceMember(projectId);
        allow create: if isWorkspaceMember(projectId)
          && request.resource.data.id == messageId
          && request.resource.data.senderId == uid()
          && request.resource.data.content is string
          && request.resource.data.content.size() >= 1
          && request.resource.data.content.size() <= 2000;
        allow update: if false;
        allow delete: if isWorkspaceMember(projectId) && resource.data.senderId == uid();
      }
    }

    match /bounties/{bountyId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.reportedById == uid()
        && request.resource.data.id == bountyId
        && request.resource.data.status == 'Open'
        && !request.resource.data.keys().hasAny(['assignedTo', 'assignedToName', 'githubPrUrl', 'solutionNotes', 'arbitrationResult', 'buyerId'])
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.title.size() <= 300;
      allow update: if signedIn()
        && request.resource.data.id == resource.data.id
        && request.resource.data.reportedById == resource.data.reportedById
        && request.resource.data.projectId == resource.data.projectId
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          (
            resource.data.status == 'Open'
            && request.resource.data.status == 'Claimed'
            && resource.data.reportedById != uid()
            && request.resource.data.assignedTo == uid()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'assignedTo', 'assignedToName', 'claimedAt'])
          )
          ||
          (
            resource.data.status == 'Claimed'
            && request.resource.data.status == 'InReview'
            && resource.data.assignedTo == uid()
            && request.resource.data.githubPrUrl is string
            && request.resource.data.githubPrUrl.matches('^https://github\\.com/[^/ ]+/[^/ ]+/pull/[0-9]+.*$')
            && request.resource.data.solutionNotes is string
            && request.resource.data.solutionNotes.size() >= 15
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'githubPrUrl', 'solutionNotes', 'submittedAt', 'rejectionReason'])
          )
          ||
          (
            resource.data.status == 'InReview'
            && request.resource.data.status == 'Solved'
            && resource.data.reportedById == uid()
            && resource.data.githubPrUrl is string
            && resource.data.solutionNotes is string
            && request.resource.data.solvedById == resource.data.assignedTo
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'solvedAt', 'solvedById', 'solvedByName'])
          )
          ||
          (
            resource.data.status == 'InReview'
            && request.resource.data.status == 'Claimed'
            && resource.data.reportedById == uid()
            && request.resource.data.rejectionReason is string
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'rejectionReason', 'rejectedAt'])
          )
          ||
          (
            resource.data.status != 'Solved'
            && resource.data.reportedById == uid()
            && resource.data.githubPrUrl is string
            && resource.data.solutionNotes is string
            && (
              (
                request.resource.data.status == 'Solved'
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'arbitrationResult', 'arbitrationRequestedBy', 'arbitratedAt', 'solvedAt', 'solvedById', 'solvedByName'])
                && request.resource.data.solvedById == resource.data.assignedTo
              )
              ||
              (
                request.resource.data.status == 'Claimed'
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'arbitrationResult', 'arbitrationRequestedBy', 'arbitratedAt', 'rejectionReason'])
              )
            )
            && request.resource.data.arbitrationRequestedBy == uid()
          )
        );
      allow delete: if signedIn() && resource.data.reportedById == uid();
    }

    match /exclusive_assets/{assetId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.id == assetId
        && request.resource.data.artistId == uid()
        && request.resource.data.sold == false
        && request.resource.data.archiveStoragePath is string
        && request.resource.data.archiveStoragePath.matches('^exclusive-assets/' + uid() + '/' + assetId + '/.+$')
        && request.resource.data.archiveFileName is string
        && request.resource.data.archiveFileSize is number
        && request.resource.data.archiveFileSize > 0
        && request.resource.data.archiveFileSize <= 50 * 1024 * 1024
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 2;
      allow update: if signedIn()
        && request.resource.data.id == resource.data.id
        && request.resource.data.artistId == resource.data.artistId
        && request.resource.data.archiveStoragePath == resource.data.archiveStoragePath
        && request.resource.data.archiveFileName == resource.data.archiveFileName
        && request.resource.data.archiveFileSize == resource.data.archiveFileSize
        && (
          (
            resource.data.artistId == uid()
            && resource.data.sold == false
            && request.resource.data.sold == false
            && request.resource.data.archiveStoragePath is string
          )
          ||
          (
            resource.data.sold == false
            && request.resource.data.sold == true
            && request.resource.data.buyerId == uid()
            && resource.data.artistId != uid()
            && get(/databases/$(database)/documents/projects/$(request.resource.data.buyerProjectId)).data.ownerId == uid()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sold', 'buyerProjectId', 'buyerProjectTitle', 'buyerId', 'transactionId'])
          )
        );
      allow delete: if signedIn() && resource.data.artistId == uid() && resource.data.sold == false;
    }

    match /connections/{connectionId} {
      allow read: if isConnectionMember(resource.data);
      allow create: if signedIn()
        && request.resource.data.id == connectionId
        && request.resource.data.fromUserId == uid()
        && request.resource.data.status == 'pending'
        && isValidConnection(request.resource.data);
      allow update: if signedIn()
        && isConnectionMember(resource.data)
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.toUserId == resource.data.toUserId
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && isValidConnection(request.resource.data)
        && (
          (
            resource.data.toUserId == uid()
            && request.resource.data.status in ['accepted', 'declined']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt'])
          )
          || (
            resource.data.fromUserId == uid()
            && request.resource.data.status == resource.data.status
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['message'])
          )
        );
      allow delete: if isConnectionMember(resource.data);
    }

    match /studio_join_requests/{requestId} {
      allow read: if signedIn() && (resource.data.userId == uid() || resource.data.ownerId == uid());
      allow create: if signedIn()
        && request.resource.data.id == requestId
        && request.resource.data.userId == uid()
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.studioId == resource.data.studioId
        && resource.data.ownerId == uid();
      allow delete: if signedIn() && (resource.data.userId == uid() || resource.data.ownerId == uid());
    }

    match /messages/{messageId} {
      allow read: if signedIn() && uid() in resource.data.participantIds;
      allow create: if signedIn() && isValidMessage(request.resource.data);
      allow update: if signedIn()
        && uid() in resource.data.participantIds
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
        && request.resource.data.readBy.hasAny([uid()]);
      allow delete: if signedIn() && resource.data.senderId == uid();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == uid();
      allow create: if signedIn()
        && request.resource.data.userId is string
        && request.resource.data.title is string
        && request.resource.data.message is string;
      allow update: if signedIn()
        && resource.data.userId == uid()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      allow delete: if signedIn() && resource.data.userId == uid();
    }

    match /{document=**} {
      allow read, write: if false;
    }

    // Game Jams — Studio owners create, all can read published jams
    match /game_jams/{jamId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.organizerId == uid()
                    && request.resource.data.keys().hasAll(['title', 'organizerId', 'studioId', 'status'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() >= 3
                    && request.resource.data.title.size() <= 200;
      allow update: if signedIn()
                    && resource.data.organizerId == uid()
                    && request.resource.data.organizerId == resource.data.organizerId
                    && request.resource.data.studioId == resource.data.studioId;
      allow delete: if signedIn() && resource.data.organizerId == uid();
    }

    // Jam Registrations — participants register for jams
    match /jam_registrations/{regId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.keys().hasAll(['jamId', 'userId', 'type', 'registeredAt'])
                    && request.resource.data.userId == uid();
      allow update: if signedIn()
                    && resource.data.userId == uid()
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.jamId == resource.data.jamId;
      allow delete: if signedIn() && resource.data.userId == uid();
    }

    // Jam Teams — team creation and member management
    match /jam_teams/{teamId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.keys().hasAll(['jamId', 'leaderId', 'teamName', 'createdAt'])
                    && request.resource.data.leaderId == uid();
      allow update: if signedIn()
                    && resource.data.leaderId == uid()
                    && request.resource.data.jamId == resource.data.jamId
                    && request.resource.data.leaderId == resource.data.leaderId;
      allow delete: if signedIn() && resource.data.leaderId == uid();
    }

    // Jam Votes — community voting (immutable once cast, one per voter per jam)
    match /jam_votes/{voteId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.keys().hasAll(['jamId', 'voterId', 'targetId', 'targetType', 'createdAt'])
                    && request.resource.data.voterId == uid();
      allow update: if false;
      allow delete: if false;
    }

    // User Points — global point ledger (append-only, self-only)
    match /user_points/{pointId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.keys().hasAll(['userId', 'amount', 'source', 'description', 'createdAt'])
                    && request.resource.data.userId == uid()
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0
                    && request.resource.data.amount <= 1000;
      allow update: if false;
      allow delete: if false;
    }

    // --- Learn Hub Collections (Secure by default, managed via Server REST APIs) ---
    match /ai_provider_connections/{userId} {
      allow read, write: if false;
    }

    match /learning_scan_runs/{runId} {
      allow read, write: if false;
    }

    match /learning_keywords/{keywordId} {
      allow read, write: if false;
    }

    match /learning_sources/{sourceId} {
      allow read, write: if false;
    }

    match /learning_opportunities/{opportunityId} {
      allow read: if true; // In development/production we can query all or public from client if desired, but let's restrict public reads:
      // Allow read for everyone if status is published
      allow get, list: if resource == null || resource.data.status == 'published';
      allow write: if false;
    }
  }
}
