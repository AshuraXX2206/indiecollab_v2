# VITE_GEMINI_API_KEY: Required for Gemini AI API calls (client-side via Vite).
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Client configuration for self-hosted / third-party deployments.
# If these are provided, the app will override details in firebase-applet-config.json.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_DATABASE_ID="" # Set only if using a custom database ID, otherwise uses "(default)"

# Firebase Admin configuration for the Backend Server (if different from client).
# Optional: project ID for Firebase Admin SDK (defaults to VITE_FIREBASE_PROJECT_ID or firebase-applet-config.json)
FIREBASE_PROJECT_ID=""

# FIREBASE_SERVICE_ACCOUNT_KEY: Optional. Absolute path to a Firebase Service Account JSON file.
# Used for Admin SDK authentication in production instead of viewer-only fallback.
# FIREBASE_SERVICE_ACCOUNT_KEY="C:\\path\\to\\service-account.json"

# ADMIN_SECRET_KEY: Required to enable destructive admin maintenance endpoints.
# If this is omitted, /api/admin/clear-firebase and /api/admin/clean-users return 503.
ADMIN_SECRET_KEY="replace_with_a_long_random_secret"
